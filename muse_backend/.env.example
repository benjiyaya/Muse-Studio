# Muse Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── HuggingFace token (required for gated models, e.g. FLUX.2-klein-9B) ───────
# Create at https://huggingface.co/settings/tokens — read access is sufficient
# Accept the FLUX Non-Commercial License at https://huggingface.co/black-forest-labs/FLUX.2-klein-9B first
HF_TOKEN=hf_...

# ── LLM (Story Muse) ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
#
# Optional: LM Studio local LLM server (OpenAI-compatible API)
# LMSTUDIO_BASE_URL=http://127.0.0.1:1234
# LMSTUDIO_MODEL=gpt-4o-mini
# LMSTUDIO_API_KEY=your_token_if_enabled

# ── Video API Providers (Motion Muse) ─────────────────────────────────────────
KLING_API_KEY=
SEEDDANCE_API_KEY=
RUNWAY_API_KEY=

# ── Optional: Override models path (default is ../models relative to this folder) ──
# Uncomment and set if your models live on a different drive
# MODEL_BASE_PATH=D:/AI_Models/muse

# ── Optional: Local ASR model for Video Editor Agent (onnx-asr + ONNX Whisper) ──
# Path to an ONNX ASR model directory compatible with `onnx-asr.load_model`.
# Example (adjust to your environment):
# MUSE_ASR_MODEL_ID=e:/MuseAgent_KanbunPM/v3_src/muse_backend/models/onnx-asr/whisper-small-pt
